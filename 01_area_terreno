.data
	msg1: .asciiz "base: "
	msg2: .asciiz "altura: "
	msg3: .asciiz "area terreno: "
.text

.globl main

main:
	li $v0, 4
	la $a0, msg1
	syscall 
	
	li $v0, 5
	syscall
	add $t1, $v0, 0
	
	li $v0, 4
	la $a0, msg2
	syscall
	
	li $v0, 5
	syscall
	mul $t1, $t1, $v0
	
	li $v0, 4
	la $a0, msg3
	syscall
	
	li $v0, 1
	add $a0, $t1, 0
	syscall
	
		
